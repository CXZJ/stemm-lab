# Copy to .env and fill in your Firebase / Google keys.
# Expo loads EXPO_PUBLIC_* at build time.

# Firebase (Web SDK config from Firebase Console → Project settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional: measurement
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Maps (for react-native-maps — Dev Client / prebuild)
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# AdMob application IDs (use Google test IDs in development)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511

# Banner unit IDs (test units below)
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-3940256099942544/6300978111
EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-3940256099942544/2934735716

# Android: path to google-services.json (for FCM native layer when using EAS)
GOOGLE_SERVICES_JSON=

# EAS (optional override)
EAS_PROJECT_ID=

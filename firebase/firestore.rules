rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userTeamId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId;
    }

    function sameTeam(teamId) {
      return signedIn() && userTeamId() == teamId;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /teams/{teamId} {
      allow read: if sameTeam(teamId);
      allow create: if signedIn();
      allow update: if sameTeam(teamId);
      allow delete: if false;
    }

    match /teamMembers/{memberId} {
      allow read: if signedIn() &&
        resource.data.teamId == userTeamId();
      allow create: if signedIn();
      allow update: if signedIn() &&
        resource.data.teamId == userTeamId();
      allow delete: if false;
    }

    match /attempts/{attemptId} {
      allow read: if signedIn() &&
        resource.data.teamId == userTeamId();
      allow create: if signedIn() &&
        request.resource.data.teamId == userTeamId() &&
        request.resource.data.createdByUid == request.auth.uid;
      allow update: if signedIn() &&
        resource.data.teamId == userTeamId();
      allow delete: if false;
    }

    match /media/{mediaId} {
      allow read: if signedIn() &&
        resource.data.teamId == userTeamId();
      allow create: if signedIn() &&
        request.resource.data.teamId == userTeamId();
      allow update: if signedIn() &&
        resource.data.teamId == userTeamId();
      allow delete: if false;
    }

    match /notifications/{notifId} {
      allow read: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /leaderboards/{docId} {
      match /entries/{entryId} {
        allow read: if signedIn();
        allow create, update: if signedIn() &&
          request.resource.data.teamId == userTeamId();
        allow delete: if false;
      }
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /syncQueue/{itemId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
    }
  }
}
